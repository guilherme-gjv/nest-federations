{
  "name": "posts",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/posts/src",
  "projectType": "application",
  "targets": {
    "compile": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/posts",
        "main": "apps/posts/src/main.ts",
        "tsConfig": "apps/posts/tsconfig.app.json",
        "assets": [
          {
            "glob": "**/*.graphql",
            "input": "apps/posts/src",
            "output": "./"
          }
        ]
      },
      "configurations": {
        "production": {
          "optimization": true
        }
      }
    },
    "serve": {
      "executor": "@nx/js:node",
      "options": {
        "buildTarget": "posts:compile",
        "watch": true,
        "inspect": false
      },
      "configurations": {
        "production": {
          "buildTarget": "posts:compile:production"
        }
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "nx serve posts"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "nx serve posts"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
